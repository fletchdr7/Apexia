# Apexia AI backend configuration

# OpenAI (or compatible). Leave blank to run with heuristic fallbacks.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

# Optional: verify Supabase user JWTs (Project Settings -> API -> JWT Secret)
REQUIRE_AUTH=false
SUPABASE_JWT_SECRET=

# CORS: comma-separated origins, or * for all
ALLOWED_ORIGINS=*
