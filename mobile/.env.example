# Apexia mobile app configuration
# Copy to `.env` and fill in. All values are inlined at build time (public).

# Supabase (https://app.supabase.com -> Project Settings -> API)
EXPO_PUBLIC_SUPABASE_URL= 
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Python AI backend base URL (e.g. https://yourname.pythonanywhere.com)
# Leave blank to run the app with local heuristic AI (demo mode).
EXPO_PUBLIC_AI_API_URL=
