{
  "expo": {
    "name": "Apexia",
    "slug": "apexia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "apexia",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arrowbaysolutions.apexia",
      "infoPlist": {
        "NSCameraUsageDescription": "Apexia uses the camera to scan food labels and cooked meals so it can estimate their nutrition.",
        "NSPhotoLibraryUsageDescription": "Apexia lets you pick photos of meals and supplement labels to analyze their nutrition.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.arrowbaysolutions.apexia",
      "adaptiveIcon": {
        "backgroundColor": "#ECFDF5",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-image",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Apexia uses the camera to scan food labels and cooked meals so it can estimate their nutrition."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Apexia lets you pick photos of meals and supplement labels to analyze their nutrition."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "35f8c071-9d17-418e-978a-ed3906e63960"
      }
    }
  }
}
